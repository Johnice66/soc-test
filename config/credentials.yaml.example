# 凭据配置样板 —— 复制到 credentials.yaml 后填实际值，credentials.yaml 已 gitignore
# 任一段缺失或留空，相关 fixture 会自动 pytest.skip 对应用例

# 1) 平台前端登录（如果某些 API 需要 Cookie/JWT）
platform:
  enabled: false
  username: ""
  password: ""
  # 或直接给已登录的 cookie / bearer
  cookie: ""
  bearer: ""

# 2) Wazuh Manager API (55000)
wazuh_api:
  enabled: false
  host: "192.168.1.193"
  port: 55000
  username: "wazuh"
  password: ""
  verify_tls: false

# 3) Wazuh Indexer (OpenSearch 9200) —— 直接查 wazuh-alerts-* 索引
wazuh_indexer:
  enabled: false
  host: "192.168.1.193"
  port: 9200
  username: "admin"
  password: ""
  verify_tls: false

# 4) 被测主机 SSH（用于产生 SSH 爆破 / 提权 / 计划任务等真实日志）
ssh_host:
  enabled: false
  host: "192.168.1.193"
  port: 22
  username: "soc-test"
  password: ""
  # 或私钥
  private_key_path: ""
  # 测试账号（用于 SSH 爆破的攻击目标账号）
  victim_account: "testuser"
  # 受控攻击源 IP（即测试发起方），用于 Wazuh 关联
  attacker_source_ip: ""
