SOC_CONSOLE_ADMIN_USERNAME=admin
SOC_CONSOLE_ADMIN_PASSWORD=change-this-to-a-long-random-password
# 经 HTTPS 反向代理访问时改为 true
SOC_CONSOLE_SECURE_COOKIE=false

